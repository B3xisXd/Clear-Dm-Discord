# ⚠️ CONFIGURAÇÃO DE EXEMPLO - NÃO USE EM PRODUÇÃO
# Copie este arquivo para config.js e adicione seus valores reais

# Seu token do Discord
# ⚠️ NUNCA compartilhe seu token!
# Como obter: F12 → Application → Local Storage → token
TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Intervalo entre deletações de mensagens (em milissegundos)
# Valores: 500-2000
# Padrão: 750 (recomendado)
DELETE_INTERVAL=750

# Delay antes de iniciar a limpeza (em milissegundos)
# Dá tempo para você confirmar e preparar
START_DELAY=2000
